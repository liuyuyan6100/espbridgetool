# ---- Serial Bridge 配置 ----

# 串口配置
SERIAL_PORT=COM6
SERIAL_BAUD=115200

# Web 服务
HOST=127.0.0.1
HTTP_PORT=8080

# 日志
LOG_MAX_LINES=10000
LOG_LEVEL=INFO

# ESP-IDF 集成（可选，留空则禁用编译/烧录功能）
# 项目目录（edge_agent 工程根目录，含 CMakeLists.txt）
IDF_PROJECT_DIR=

# ESP-IDF export.ps1 路径
IDF_EXPORT_SCRIPT=C:\esp\v5.5.4\esp-idf\export.ps1

# Board Manager 配置
# boards 目录路径（相对 IDF_PROJECT_DIR 或绝对路径）
IDF_BOARDS_DIR=boards

# 默认板型（立创·实战派 ESP32-S3）
IDF_BOARD=lckfb_szpi_esp32s3
